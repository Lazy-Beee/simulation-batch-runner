{
  "simulator": {
    "default_exe": "simulator.exe",
    "zip_path": "7z.exe",
    "zip_ext": ".7z",
    "zip_args": ["-mx=5", "-mmt=on", "-m0=lzma2"],
    "zip_async": true
  },
  "upload": {
    "enabled": false,
    "async": true,
    "rclone_path": "rclone",
    "remote": "gdrive:batch_output/",
    "eta_step_percent": 20,
    "args": ["--drive-chunk-size", "128M", "--timeout", "300s", "--contimeout", "60s", "--low-level-retries", "10", "--retries", "3", "--drive-stop-on-upload-limit"]
  },
  "simulator_profiles": [
    {
      "name": "simulator",
      "path_marker": "project_path",
      "supports_mpi": false,
      "step_pattern": "\\[step\\] (.*)",
      "default_omp": false,
      "default_mpi": false,
      "eta_pattern": "eta:\\s*(\\S+)"
    }
  ],
  "defaults": {
    "omp_threads": 24,
    "mpi_ranks": 4,
    "zip": true,
    "cleanup": "folder",
    "parallel_cases": 1
  },
  "telegram": {
    "enabled": false,
    "bot_token": "",
    "chat_id": ""
  }
}

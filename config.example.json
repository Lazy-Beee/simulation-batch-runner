{
  "simulator": {
    "default_exe": "simulator.exe",
    "zip_path": "7z.exe",
    "zip_ext": ".7z",
    "zip_args": ["-mx=5", "-mmt=4", "-m0=lzma2"]
  },
  "simulator_profiles": [
    {
      "name": "simulator",
      "path_marker": "project_path",
      "supports_mpi": false,
      "step_pattern": "\\[step\\] (.*)",
      "default_omp": false,
      "default_mpi": false,
      "eta_pattern": "eta:\\s*(\\S+)"
    }
  ],
  "defaults": {
    "omp_threads": 24,
    "mpi_ranks": 4
  },
  "telegram": {
    "enabled": false,
    "bot_token": "",
    "chat_id": ""
  }
}
